# Unlocked AI Configuration Template

# OpenRouter API Key (https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenCode API (Zen/Go Proxies) Settings
OPENCODE_API_KEY=your_opencode_api_key_here
OPENCODE_BASE_URL=https://api.opencode.example.com/v1

# Ollama Settings (Local Execution)
OLLAMA_BASE_URL=http://localhost:11434

# Native Free Tiers
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Default Models (Optional, can be overridden)
DEFAULT_OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free
DEFAULT_OPENCODE_MODEL=qwen/qwen-2.5-coder-32b
DEFAULT_OLLAMA_MODEL=qwen2.5-coder:7b
DEFAULT_GEMINI_MODEL=gemini-2.5-flash
DEFAULT_GROQ_MODEL=llama3-8b-8192
